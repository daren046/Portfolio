# Clé Web3Forms (recommandé) — gratuit sur https://wb3forms.com
# 1. Entrez tagnandaren@gmail.com
# 2. Copiez la clé reçue par email
# 3. Renommez ce fichier en .env
VITE_WEB3FORMS_ACCESS_KEY=votre_cle_ici

# Sans clé Web3Forms, le formulaire utilise FormSubmit (formsubmit.co).
# La première soumission déclenche un email de confirmation à tagnandaren@gmail.com.

# URLs des demos live (optionnel)
VITE_PORTFOLIO_LIVE_URL=https://daren046.github.io/Portfolio/
